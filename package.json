{
  "name": "custom-theme-maker",
  "displayName": "Custom Theme Maker",
  "description": "Kill the rainbow with a custom live theme editor.",
  "version": "0.0.1",
  "publisher": "your-name", 
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
  "viewsContainers": {
    "activitybar": [
      {
        "id": "theme-maker-sidebar",
        "title": "Custom Theme Maker",
        "icon": "$(paintcan)"
      }
    ]
  },
  "views": {
    "theme-maker-sidebar": [
      {
        "type": "webview",
        "id": "theme-maker-view",
        "name": "Live Theme Editor"
      }
    ]
  }
},
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.11",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
